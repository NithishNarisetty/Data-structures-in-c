#include <stdio.h>

#define MAX 5

int queue[MAX];
int front = -1, rear = -1;

void enqueue(int doc) {
    if(rear == MAX - 1) {
        printf("Queue Overflow\n");     // queue full
        return;
    }
    if(front == -1)
        front = 0;     // first element

    queue[++rear] = doc;     // insert document
    printf("Document %d added\n", doc);
}

void dequeue() {
    if(front == -1 || front > rear) {
        printf("Queue Underflow\n");     // queue empty
        return;
    }

    printf("Printing Document %d\n", queue[front]);   // print doc
    front++;     // remove from queue
}

void display() {
    int i;

    if(front == -1 || front > rear) {
        printf("No pending documents\n");   // empty queue
        return;
    }

    printf("Pending Documents: ");
    for(i = front; i <= rear; i++) {
        printf("%d ", queue[i]);     // display queue
    }
    printf("\n");
}

int main() {
    int choice, doc;

    while(1) {
        printf("\n1.Add 2.Print 3.Display 4.Exit\n");   // menu
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                printf("Enter document number: ");
                scanf("%d", &doc);
                enqueue(doc);
                break;

            case 2:
                dequeue();
                break;

            case 3:
                display();
                break;

            case 4:
                return 0;     // exit

            default:
                printf("Invalid choice\n");
        }
    }
}
